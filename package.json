{
  "name": "@qrkit/bc-ur-web",
  "version": "2.0.1",
  "author": "Irfan Bilaloğlu <irfanbilaloglu@gmail.com>, Pieter Uyttersprot <pieter.uyttersprot@ngrave.io>, Antonis Poulakis <antwnic4@gmail.com>",
  "contributors": [
    "Mladen Milankovic <developer@mmlado.com>"
  ],
  "description": "Browser-native JavaScript implementation of Blockchain Commons UR for Node.js and browsers",
  "license": "MIT",
  "directories": {
    "lib": "src",
    "test": "tests"
  },
  "files": [
    "src",
    "dist",
    "index.html"
  ],
  "scripts": {
    "clean": "rimraf dist && rimraf tsconfig.tsbuildinfo",
    "build": "yarn clean && yarn compile",
    "compile": "tshy",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "prepublishOnly": "yarn build",
    "lint": "eslint \"./src/**/*.{ts,tsx}\" --max-warnings=0",
    "start": "live-server --watch=src,dist --port=8080"
  },
  "dependencies": {
    "cbor2": "^1.8.0"
  },
  "devDependencies": {
    "@amanda-mitchell/semantic-release-npm-multiple": "^3.17.0",
    "@rollup/plugin-commonjs": "^28.0.2",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@types/jest": "^29.5.13",
    "@types/node": "^22.7.4",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.2.0",
    "jest": "^29.7.0",
    "live-server": "^1.2.1",
    "rimraf": "^6.0.1",
    "rollup": "^4.28.1",
    "rollup-plugin-node-polyfills": "^0.2.1",
    "ts-jest": "^29.2.5",
    "tshy": "^3.0.2",
    "tslib": "^2.8.1",
    "typescript": "5.6.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mmlado/bc-ur-web.git"
  },
  "keywords": [
    "bc-ur"
  ],
  "bugs": {
    "url": "https://github.com/mmlado/bc-ur-web/issues"
  },
  "homepage": "https://github.com/mmlado/bc-ur-web#readme",
  "tshy": {
    "exports": {
      "./package.json": "./package.json",
      ".": "./src/index.ts"
    },
    "dialects": [
      "esm"
    ],
    "include": [
      "./src/**/*.ts",
      "./src/**/*.tsx",
      "./src/**/*.json"
    ]
  },
  "type": "module",
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      }
    }
  },
  "module": "./dist/esm/index.js"
}
